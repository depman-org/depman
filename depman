const NAME = 'Depman'
const VERSION = '0.1.0'
const NU_VERSION = '0.97.1'
const tool_dir: path = ['.' ($NAME | str downcase)] | path join
const config_file: path = [ $tool_dir 'config.toml'] | path join
const deps_file: path = [ $tool_dir 'dependencies.toml'] | path join
const lock_file: path = [ $tool_dir 'dependencies.lock'] | path join
const build_file: path = [ $tool_dir 'build.nu'] | path join
const cache_dir: path = [ $tool_dir 'cache/'] | path join

def main [command: string, --depset (-d): string]: nothing -> nothing {
	let cur_depset: string = $depset | default 'default'

	let nu_version: string = try { (version).version } catch { 'unknown' }
	if $nu_version != $NU_VERSION {
		error $"Your Nushell version is not compatible with ($NAME). Required Nushell version is ($NU_VERSION).\nYou can download different versions of Nushell here: https://github.com/nushell/nushell/releases"
	}
	
	$env.ENV_CONVERSIONS.DEPMAN = {
		to_string: { to nuon }
		from_string: { from nuon }
	}
	
	$env.DEPMAN.source_dir = $env.PWD
	
	if not ($tool_dir | path exists) {
		print $'There is no "($tool_dir)" directory in the current directory. Do you want to create one? (Y/n)'
		[Yes No] | input list -f
		| if $in == 'Yes' {
			main init
		}
		exit
	}

	if ($config_file | path exists) {
		
	}

	if not ([$deps_file $build_file $lock_file ] | any {path exists}) {
		error $"None of a '($build_file)'' build script, '($deps_file)'' file, or a '($lock_file)' lockfile is found. Run 'depman init' to create a blank template."
	}

	if ($deps_file | path exists) {
		let config = open $deps_file
		let deps: table = $config | parse_deps
		check_deps $deps
		
		let depsets: table<name: string, config: record> = parse_depsets $config.depsets $deps.depsets
		check_depsets $depsets $deps
		let deps_to_acquire: table<name: string, source: table, dir: int, command: record> = (
			$deps
			| each { dep_source_from_cur_depset $cur_depset $depsets }
			| flatten
			| insert dir { get_dep_cache_dir }
			| insert command { create_command }
			| insert lock { get_lock_status $cur_depset $depsets }
		)

		prt ($deps_to_acquire | reject command.closure)
		prt '------------------------------------------------------------------'
			
		# $env.DEPMAN.dependencies = $dep_paths
	}
	ignore
}


