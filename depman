# Execute a closure without disrupting the pipeline.
# The difference between this and 'tee' is this doesn't modify the input under no circumstances and is synchronous.
def run [
	closure: closure   # A closure to run. Input: the input (any). Parameters: the input (any).
]: any -> any {
	let input = $in
	$input | do $closure $input
	$input
}

# Converts the list into an English recounting.
def recount [
	--and (-a)   # Delimit the last item with 'and' instead of 'or'.
]: list<string> -> string {
	each { $'"($in)"'}
	| chunks ($in | length | [($in - 1), 1] | math max)
	| each { str join ', ' }
	| str join (
		if $and {' and '} else {' or '} 
	)
}

# Assigns default values to keys of a record or list of records.
def defaults [defaults: record]: [list<record> -> list<record>, record -> record] {
    each {|it|
        $defaults
        | merge $it
    }
}

def error [message: string] nothing -> nothing {
	error make --unspanned {msg: $message}
}

def prt [value?: any, --json (-j)]: any -> any {
	let input = $in
	def convert []: any -> string {
		if $json {
			to json
		} else {
			to nuon
		}
	}
	if $input == null and $value == null {
		error "There is neither stdin nor value provided to prt."
	}
	if $value != null {
		$value | convert | print $in
	} else if $input != null {
		$input | convert | print $in
	}
	$input
}

# Check that the input list has only one non-nothing item. If so, return it. Otherwise error with given message.
def filter-one [
	none_err: string        # The error message to use if no items match.
	multiple_err: closure   # A closure to construct an error message with, to use when more than one item matches. Input: input list (list<any>). Parameters: matching items (list<any>). Output: string.
	predicate?: closure     # If given, test whether elements in the input list fullfill this predicate instead. Input: input list (list<any>). Parameters: repeat item (any). Output: bool.
]: list<any> -> any {
	let input = $in
	$input
	| filter ($predicate | default {|it| $it != null})
	| match ($in | length) {
		0 => { error $none_err },
		1 => { $in | first },
		_ => { 
			let matches: list<any> = $in
			error ($input | do $multiple_err $matches) 
		}
	}
}

# Check type of input, and throw an error if it doesn't match.
def check-type [
	...types: string          # Type descriptions to check for. Syntax is the same as 'describe' command output.
	--cmd-name (-c): string   # Name of the command to auto-generate an error message from.
	--err-msg (-m): closure   # A closure to generate a customized error message with. Parameters: input value (any), input value type (string), an English recounting of accepted types (string).
	--structured (-e)         # Match a nested structured data types, instead of just the general type.
	--no-error (-n)           # Don't throw an error and return the check result (bool) instead.
	]: any -> any {
	let input = $in

	def _check-type [args: record<types: list<string>, cmd_name: any, structured: bool, no_error: bool>]: any -> nothing {
		let value = $in
		let types = $args.types
		let cmd_name = $args.cmd_name
		let structured = $args.structured
		let no_error = $args.no_error
		let value_type: string = do {
			$value | describe
			| do-if (not $structured) { get_basic_type }
		}

		$types
		| err-if-any {|type|
			let is_structured_type = ($type | get_basic_type) != $type
			$structured != $is_structured_type
		} {|type|
			if $structured {
				$"check-type: You specified the --structured \(-s\) flag but provided a basic data type to check against: \"($type)\". \nPlease provide a structured type instead, like \"list<($type)>\"."
			} else {
				let simple_type: string = $type | get_basic_type
				$"check-type: You didn't specify the --structured \(-s\) flag but provided a structured data type to check against: \"($type)\". \nPlease provide a simple type instead, like \"($simple_type)\"."
			}
		}

		if (($value_type in $types) or
			(	# An empty list should match a list containing any type.
				$value_type == 'list<any>' and
				($value | is-empty ) and
				($types | any {($in | get_basic_type) == 'list'})
			)
		) {
			if $no_error { true }
		} else {
			let types_str: string = $types	| recount
			let err_msg: string = (
				$err_msg
				| default { $"Invalid value given to command \"($cmd_name)\". Expected a value with a type of ($types_str). Found value of type \"($value_type)\":\n($value)" }
				| do $in $value $value_type $types_str
			)
			if $no_error { false } else {
				error $err_msg
			}
		}
	}

	[
		{'--cmd-name (-c)': $cmd_name}
		{'--err-msg (-m)': $err_msg}
		{'--no-error (-n)': $no_error}
	]
	| run {
		each { 
			do-if ($in | get_simple_type | $in == closure) {'closure'}
			| prt $in
	}
	| filter-one $'check-type: You must provide at least one of the flags ($in | columns | recount).' {|matches| $"check-type: You provided ($matches | columns | recount --and) flags. Please provide only one." } {|it| ($it | values).0 | != null}
	
	
	$types | _check-type {types: ['list<string>'], cmd_name: 'check-types', structured: true, no_error: false}
	
	$input 
	| _check-type {types: $types, cmd_name: $cmd_name, structured: $structured, no_error: $no_error}
	| do-if (not $no_error) {
		$input
	}

}

# Get the basic type from a type description.
def get_basic_type []: string -> string {
	str replace --regex '<.*' ''
}

# Check values in a pipeline against a condition and error if check fails.
# The difference with each { err-if } is err-if-any will only accept list input.
def err-if-any [
	condition: closure   # A condition to check with every item. Input: repeat item (any). Parameters: repeat item (any). Output: bool.
	error_msg: closure   # A closure to generate an error message with. Input: failed item (any). Parameters: failed item (any), input list (list<any>). Output: string.
	--not                # Negate the condition.
]: [list<any> -> list<any>] {
	let list = $in
	$list
	| each {|it|
		err-if ($not xor ($it | do $condition $it)) ($it | do $error_msg $it $list)
	}
}

# Check the input against a condition and error if check passes.
def err-if [
	condition: bool   # A condition to check for.
	err_msg: string   # An error message.
	--not             # Negate the condition.
]: any -> any {
	do-if ($condition xor $not) {
		error $err_msg
	}
}

# Conditionally run a closure on the input.
def do-if [
	condition: bool   # A condition to check for.
	then: closure     # A closure to run on input if the condition is true. Input: input (any). Parameters: input (any).
]: any -> any {
	if $condition {
		$in | do $then $in
	} else { $in }
}

# Test if every element in the input is an item in a list, is part of a string, or is a key in a record.
def all-in [
	operand: any            # A string, list, or record to check inclusion in.
	--error (-e): closure   # If given, create an error if any given item is not in the input, with an error message determined by the given closure. Input: nonexistent item (any). Parameters: nonexistent item (any), the operand (any).
]: list<any> -> bool {
	if $error != null {
		err-if-any {|it| $it not-in $operand} {|it| $it | do $error $it $operand}
	} else {
		all {|it| $it in $operand }
	}
}

def create_command []: record<name: string, source: table, dir: path> -> record<closure: closure, str: string> {
	let input = $in
	let dep_dir = $input.dir
	$input.source.0
	| {$in.type: $in.value}
	| match $in {
		{git: $repo} => {
			let ref = [$repo.commit? $repo.branch?] | where $it != null | get -i 0
			if $ref != null {
				{ 
					closure: { git clone -b $ref $repo.url $dep_dir },
					str: $"git clone -b '($ref)' '($repo.url)' '($dep_dir)'"
				}
			} else {
				{ 
					closure: { git clone $repo.url $dep_dir },
					str: $"git clone '($repo.url)' '($dep_dir)'"
				}
			}
		},
		{http: {url: $url, redirect-mode: $redirect_mode}} => {
			let redirect_mode: string = $redirect_mode | default 'error'
			closure: { http get --redirect-mode '($redirect_mode)' ($url) | save -f $'($dep_dir)/file'},
			str: $"http get --redirect-mode '($redirect_mode)' '($url)' | save -f '($dep_dir)/file'"
		},
		{path: $path} => {
			closure: { cp -r $path $dep_dir },
			str: $"cp -r '($path)' '($dep_dir)'"
		},
		{rsync: $source} => {
			let source = ($source | str trim -r -c '/')
			{
				closure: {rsync -az $source $dep_dir},
				str: $"rsync -az '($source)' '($dep_dir)'"
			}
		},
		{cmd: $command} => {
			closure: { nu -c $command },
			str: $"nu -c '($command)'"
		}
	}
}