def create_command []: record<name: string, source: table, dir: path> -> record<closure: closure, str: string> {
	let input = $in
	let dep_dir = $input.dir
	$input.source.0
	| {$in.type: $in.value}
	| match $in {
		{git: $repo} => {
			let ref = [$repo.commit? $repo.branch?] | where $it != null | get -i 0
			if $ref != null {
				{ 
					closure: { git clone -b $ref $repo.url $dep_dir },
					str: $"git clone -b '($ref)' '($repo.url)' '($dep_dir)'"
				}
			} else {
				{ 
					closure: { git clone $repo.url $dep_dir },
					str: $"git clone '($repo.url)' '($dep_dir)'"
				}
			}
		},
		{http: {url: $url, redirect-mode: $redirect_mode}} => {
			let redirect_mode: string = $redirect_mode | default 'error'
			closure: { http get --redirect-mode '($redirect_mode)' ($url) | save -f ($dep_dir) },
			str: $"http get --redirect-mode '($redirect_mode)' '($url)' | save -f '($dep_dir)'"
		},
		{path: $path} => {
			closure: { cp -r $path $dep_dir },
			str: $"cp -r '($path)' '($dep_dir)'"
		},
		{rsync: $source} => {
			let source = ($source | str trim -r -c '/')
			{
				closure: {rsync -az $source $dep_dir},
				str: $"rsync -az '($source)' '($dep_dir)'"
			}
		},
		{cmd: $command} => {
			closure: { nu -c $command },
			str: $"nu -c '($command)'"
		}
	}
}

