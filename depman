def parse_depsets [config_depsets: any, deps_depsets: any]: nothing -> table<name: string, config: record> {	
	$deps_depsets
	| flatten
	| get name
	| uniq
	| reduce {|it, acc| $acc | merge {$it: {} } } -f {}
	| merge ($config_depsets | default {})
	| transpose name config
	| update config {
		upsert lock { default true }
		| upsert pass-default {default true}
		| upsert lock-list { default [] }
		| upsert no-lock-list { default [] }
	}
}

def check_depsets [depsets: any, deps: any]: nothing -> nothing {
	$depsets
	| each {|depset|
		let config = $depset.config
		if ($config.lock | describe) != 'bool' {
			error $'Invalid value for key "depsets.($depset.name).lock". The value must be a boolean.'
		}
		if ($config.pass-default | describe) != 'bool' {
			error $'Invalid value for key "depsets.($depset.name).pass-default". The value must be a boolean.'
		}
		if not (($config.lock-list | describe) starts-with 'list') {
			error $'Invalid value for key "depsets.($depset.name).lock-list". The value must be a list of strings.'
		}
		if not (($config.no-lock-list | describe) starts-with 'list') {
			error $'Invalid value for key "depsets.($depset.name).no-lock-list". The value must be a list of strings.'
		}
		if $config.lock == true and ($config.lock-list | is-not-empty) {
			error $'You set both "depsets.($depset.name).lock" to "true" and "depsets.($depset.name).lock-list" to a non-empty string. They are mutually exclusive.'
		}
		if $config.lock == false and ($config.no-lock-list | is-not-empty) {
			error $'You set both "depsets.($depset.name).lock" to "false" and "depsets.($depset.name).no-lock-list" to a non-empty string. They are mutually exclusive.'
		}
		$config | select lock-list no-lock-list
		| items {|key, value|
			let nonexistent_deps = ($value | filter {$in not-in $deps.name})
			if ($nonexistent_deps | is-not-empty) {
				error $'The value "($value | filter {$in not-in $deps.name} | first)" in key "depsets.($depset.name).($key)" is not among one of the dependencies specified in depman.toml.'
			}
		}
	}
}

def parse_deps []: record -> table<name: string, depsets: table> {
	let input = (
		reject -i depman depsets 
		| transpose name depsets
	)
	# Without this weird divide of first assigning the input to a variable, error messages don't work because errors are regular values in Nushell.
	$input
	| update depsets {|dep|
		let alt_depset_keys = (
			$dep.depsets
			| columns
			| filter {|key| $key not-in [http git path rsync cmd depman-cmd]}
		)
		let alt_depsets = (
			if ($alt_depset_keys | is-not-empty) { 
				$dep.depsets | select ...$alt_depset_keys
			} else {
				{}
			}
		)
		let def_depset = {default: ($dep.depsets | reject ...$alt_depset_keys)}
		let depsets = { ...$def_depset, ...$alt_depsets } | transpose name source
		
		for depset in $depsets {
			for source in $depset.source {
				if not ($source | describe | $in starts-with 'record') {
					error $'Invalid value "($source)" for depset "($depset.name)" in dependency "($dep.name)". The value must be a record with one the following keys: repo, path, get, rsync, cmd.'
				}
			}
		}

		let depsets = (
			$depsets 
			| update source {|row|
				reject -i depman-cmd
				| transpose type value
				| insert depman-cmd $row.depman-cmd?
			}
		)		
		$depsets
	}
}

def check_deps [deps: any] nothing -> nothing {
	$deps
	| each {|dep|
	 	$dep.depsets
		| each {|depset|
			let depset_str = (
				if $depset.name != default { 
					$' in depset "($depset.name)"'
				} else {""}
			)
			let source_number = ($depset.source | where type != depman-cmd | length)
			match $source_number {
				0 => { error $'No source is specified($depset_str) for dependency "($dep.name)".' },
				1 => {
					let source = $depset.source.0
					match $source.type {
						'git' => { 
							let repo = $source.value
							if $repo.url? == null {
								error $'You specified a repo source($depset_str) in dependency "($dep.name)" but did not specify a remote url.'
							}
							if $repo.commit? != null and $repo.branch? != null {
								error $'You specified both commit and branch in the repo source($depset_str) in dependency "($dep.name)". You can only specify one.'
							}
						},
						'http' => {
							let get = $source.value
							if $get.url? == null {
								error $'You did not specify the URL to HTTP/S GET($depset_str) in dependency "($dep.name)"'
							}
						},
						'path'|'rsync'|'cmd'|'depman-cmd' => {},
						_ => {
							error $'Unknown source type "($source.type)"($depset_str) for dependency "($dep.name)".'	
						}
					}
				},
				_ => { error $'There are multiple sources($depset_str) for dependency "($dep.name)".' }
			} 
		}
	}
}

