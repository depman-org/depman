def get_lock_status [cur_depset: string, depsets: any]: record -> bool {
	let dep = $in
	$depsets
	| where name == $cur_depset
	| get config.0
	| if $in.lock == true and $dep.name in $in.no-lock-list {
		false
	} else if $in.lock == false and $dep.name in $in.lock-list { 
		true
	} else {
		$in.lock
	}
}

def dep_source_from_cur_depset [cur_depset: string, depsets: any]: record<name: string, depsets: table> -> record<name: string, source: table> {
	let dep = $in
	$dep.depsets
	| where name == $cur_depset
	| if ($in | is-empty) {
		let use_default = (
			$depsets
			| where name == $cur_depset
			| get 0.config.pass-default
		)
		if $use_default {
			$dep.depsets | where name == default
		} else { return }
	} else { $in }
	| {name: $dep.name, source: $in.source}
} 

def get_dep_cache_dir []: record<name: string, source: table> -> path {	
	get source
	| to nuon 
	| hash md5
	| prepend $cache_dir 
	| path join
}

def prt [value?: any, --json (-j)]: any -> any {
	let input = $in
	
	def convert []: any -> string {
		if $json {
			to json
		} else {
			to nuon
		}
	}
	
	if $input == null and $value == null {
		error "There is neither stdin nor value provided to prt."
	}
	if $value != null {
		$value | convert | print $in
	} else if $input != null {
		$input | convert | print $in
	}
	$input
}

